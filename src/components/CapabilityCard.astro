---
interface Props {
  icon: string;
  title: string;
  description: string;
  technologies: string[];
}

const { icon, title, description, technologies } = Astro.props;
---

<article class="card-hover glass-panel rounded-2xl p-6">
  <div class="font-tech mb-7 grid h-12 w-12 place-items-center rounded-2xl border border-cyan-300/25 bg-cyan-300/[0.08] text-lg font-black text-cyan-100 shadow-[0_0_26px_rgba(36,244,255,0.16)]">
    {icon}
  </div>
  <h3 class="font-tech text-base font-bold uppercase leading-7 tracking-[0.08em] text-[var(--page-text)]">{title}</h3>
  <p class="mt-3 min-h-20 text-sm leading-7 text-[var(--page-muted)]">{description}</p>
  <div class="mt-6 flex flex-wrap gap-2">
    {
      technologies.map((tech) => (
        <span class="font-tech rounded-full border border-white/10 bg-white/[0.04] px-3 py-1 text-[0.65rem] font-medium text-cyan-100/90">
          {tech}
        </span>
      ))
    }
  </div>
</article>
