---
interface Props {
  title: string;
  description: string;
  techStack: string[];
  github: string;
  demo: string;
  category: string;
}

const { title, description, techStack, github, demo, category } = Astro.props;
const initials = title
  .split(' ')
  .map((word) => word[0])
  .join('')
  .slice(0, 3)
  .toUpperCase();
---

<article class="card-hover group overflow-hidden rounded-2xl border border-[var(--page-border)] bg-[var(--page-surface)] shadow-2xl shadow-black/20">
  <div class="relative h-56 overflow-hidden bg-black">
    <div class="absolute inset-6 rounded-2xl border border-cyan-300/20 bg-[linear-gradient(135deg,rgba(0,245,255,0.14),rgba(255,255,255,0.03)_42%,rgba(0,0,0,0))] transition duration-300 group-hover:scale-[1.03]"></div>
    <div class="absolute left-8 top-8 h-3 w-24 rounded-full bg-cyan-200/40 shadow-[0_0_24px_rgba(0,245,255,0.25)]"></div>
    <div class="font-tech absolute bottom-12 right-8 text-5xl font-black tracking-[0.08em] text-cyan-100/20">{initials}</div>
    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/10 to-transparent"></div>
    <span class="font-tech absolute bottom-4 left-4 rounded-full border border-cyan-300/20 bg-black/50 px-3 py-1 text-[0.65rem] font-semibold uppercase text-cyan-100 backdrop-blur-md">
      {category}
    </span>
  </div>
  <div class="p-5 sm:p-6">
    <div class="mb-3 flex items-center justify-between gap-3">
      <h3 class="font-tech text-base font-bold uppercase leading-7 tracking-[0.06em] text-[var(--page-text)]">{title}</h3>
    </div>
    <p class="line-clamp-3 text-sm leading-7 text-[var(--page-muted)]">{description}</p>
    <div class="mt-4 flex flex-wrap gap-2">
      {techStack.map((tech) => <span class="rounded-full border border-white/10 bg-white/[0.05] px-3 py-1 text-xs text-cyan-100">{tech}</span>)}
    </div>
    <div class="mt-5 flex gap-3">
      <a href={github} class="focus-ring rounded-full border border-[var(--page-border)] px-4 py-2 text-sm font-semibold text-cyan-200 hover:border-cyan-300/50 hover:text-cyan-50" target="_blank" rel="noreferrer">
        GitHub
      </a>
      <a href={demo} class="focus-ring rounded-full border border-[var(--page-border)] px-4 py-2 text-sm font-semibold text-cyan-200 hover:border-cyan-300/50 hover:text-cyan-50" target="_blank" rel="noreferrer">
        Live Demo
      </a>
    </div>
  </div>
</article>
