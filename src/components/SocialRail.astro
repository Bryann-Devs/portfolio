---
import { profile } from '../data/profile';

const socials = [
  { href: profile.instagram, label: 'Instagram', type: 'instagram' },
  { href: profile.linkedin, label: 'LinkedIn', type: 'linkedin' },
  { href: profile.facebook, label: 'Facebook', type: 'facebook' },
];
---

<aside class="fixed left-[7.5vw] top-[48%] z-30 hidden -translate-x-1/2 -translate-y-1/2 lg:block" aria-label="Social links">
  <div class="flex flex-col items-center gap-12">
    {
      socials.map((item) => (
        <a
          href={item.href}
          target="_blank"
          rel="noreferrer"
          aria-label={item.label}
          class="focus-ring social-icon grid h-12 w-12 place-items-center rounded-full border border-white/20 bg-black/20 text-white backdrop-blur-md hover:border-white hover:bg-white hover:text-black hover:shadow-[0_0_34px_rgba(36,244,255,0.32)]"
        >
          {
            item.type === 'instagram' ? (
              <svg viewBox="0 0 24 24" aria-hidden="true" class="block h-6 w-6" fill="none">
                <rect x="5" y="5" width="14" height="14" rx="4" stroke="currentColor" stroke-width="2" />
                <circle cx="12" cy="12" r="3.2" stroke="currentColor" stroke-width="2" />
                <circle cx="16.3" cy="7.8" r="1" fill="currentColor" />
              </svg>
            ) : item.type === 'linkedin' ? (
              <svg viewBox="4 3 18 17" aria-hidden="true" class="block h-6 w-6" fill="currentColor">
                <path d="M5.38 8.18h3.49V19H5.38V8.18Zm1.75-5.37a2.02 2.02 0 1 1 0 4.04 2.02 2.02 0 0 1 0-4.04ZM10.98 8.18h3.34v1.48h.05c.46-.87 1.6-1.79 3.29-1.79 3.52 0 4.17 2.31 4.17 5.32V19h-3.49v-5.15c0-1.23-.02-2.8-1.71-2.8-1.71 0-1.97 1.34-1.97 2.72V19h-3.49V8.18Z" />
              </svg>
            ) : (
              <svg viewBox="4 4 13 20" aria-hidden="true" class="block h-6 w-6" fill="currentColor">
                <path d="M14 8.05h2.15V5.02c-.37-.05-1.64-.16-3.12-.16-3.08 0-5.19 1.88-5.19 5.34v3H4.45v3.39h3.39V24H12v-7.41h3.26l.52-3.39H12v-2.66c0-.98.27-1.65 2-1.65Z" />
              </svg>
            )
          }
        </a>
      ))
    }
  </div>
</aside>
