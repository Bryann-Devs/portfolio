---
import { profile } from '../data/profile';
---

<section id="top" class="relative grid min-h-screen place-items-center overflow-hidden bg-black px-4 pt-24">
  <div class="container-page text-center">
    <p class="font-tech mx-auto mb-6 max-w-3xl text-xs font-semibold uppercase tracking-[0.34em] text-cyan-100 sm:text-sm">
      IT Student / Web Development / UI Engineering
    </p>

    <h1 class="font-display text-cyan-gradient mx-auto max-w-6xl text-[clamp(3.75rem,15vw,11rem)] font-bold uppercase leading-[0.86] tracking-[0.045em]">
      {profile.name}
    </h1>

    <p class="mx-auto mt-8 max-w-2xl text-base leading-8 text-[var(--page-muted)] sm:text-lg">
      I build clean, responsive, and interactive web experiences with a focus on practical IT solutions.
    </p>

    <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <a
        href="/projects"
        class="focus-ring glow-button font-tech inline-flex min-h-12 items-center justify-center rounded-full px-6 text-xs font-bold uppercase tracking-[0.08em]"
      >
        View Projects
      </a>
      <a
        href="/contact"
        class="focus-ring ghost-button font-tech inline-flex min-h-12 items-center justify-center rounded-full px-6 text-xs font-bold uppercase tracking-[0.08em]"
      >
        Contact Me
      </a>
    </div>
  </div>
</section>
