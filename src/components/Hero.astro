---
import { profile } from '../data/profile';
import RotatingHeadline from './RotatingHeadline.vue';
---

<section id="top" class="relative grid min-h-screen place-items-center overflow-hidden bg-black px-4 pt-24">
  <div class="container-page text-center">
    <RotatingHeadline client:load />

    <h1 class="font-wide text-cyan-gradient mx-auto max-w-6xl text-[clamp(3.75rem,15vw,11rem)] font-bold uppercase leading-[0.86] tracking-[0.045em]">
      {profile.name}
    </h1>

    <p class="mx-auto mt-6 max-w-2xl text-base leading-8 text-[var(--page-muted)] sm:text-lg">
      I build clean, responsive, and interactive web experiences with a focus on practical IT solutions.
    </p>

    <div class="mt-9 flex justify-center">
      <a
        href="/projects"
        class="focus-ring glow-button font-sans inline-flex min-h-10 items-center justify-center rounded-full px-5 text-[16px] font-normal tracking-[0.02em]"
      >
        View Projects
      </a>
    </div>
  </div>
</section>
