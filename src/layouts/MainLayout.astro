---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import SocialRail from '../components/SocialRail.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'BryanDev',
  description = 'A modern portfolio for an IT student focused on web development, systems, networking, databases, and software projects.',
} = Astro.props;

const siteName = 'BryanDev';
const pageTitle = title === siteName ? siteName : `${title} | ${siteName}`;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&family=Michroma&family=Syncopate:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href="/favicon.svg" />
    <script is:inline>
      try {
        const savedTheme = localStorage.getItem('theme');
        document.documentElement.classList.toggle('light', savedTheme === 'light');
        document.documentElement.classList.toggle('dark', savedTheme !== 'light');
      } catch {
        document.documentElement.classList.add('dark');
      }
    </script>
    <title>{pageTitle}</title>
  </head>
  <body class="antialiased">
    <div class="flex min-h-screen flex-col">
      <Navbar />
      <SocialRail />
      <main class="flex-1">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
